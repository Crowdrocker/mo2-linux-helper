# Maintainer: Your Name <your@email.com>
# Contributor: MO2 Linux Helper Contributors

pkgname=mo2-linux-helper
pkgver=2.0.0
pkgrel=1
pkgdesc="Automated Mod Organizer 2 setup tool for Arch Linux with Proton support"
arch=('x86_64')
url="https://github.com/yourusername/mo2-linux-helper"
license=('MIT')
depends=(
    'webkit2gtk'
    'gtk3'
    'libayatana-appindicator'
    'wine'
    'winetricks'
    'curl'
    'python'
    'xdg-utils'
    'desktop-file-utils'
)
optdepends=(
    'protontricks: Proton prefix management'
    'proton-ge-custom: Recommended Proton build'
    'steam: Required for NXM links and shortcuts'
)
makedepends=(
    'rust'
    'cargo'
    'nodejs'
    'npm'
    'git'
)
provides=('mo2-linux-helper')
conflicts=()

source=(
    "git+${url}.git#tag=v${pkgver}"
)
sha256sums=('SKIP')

build() {
    cd "$srcdir/$pkgname"

    # Install JS dependencies
    npm ci

    # Build Tauri app
    npm run tauri build -- --bundles appimage,deb
}

package() {
    cd "$srcdir/$pkgname"

    # Install AppImage
    install -Dm755 "src-tauri/target/release/bundle/appimage/mo2-linux-helper_${pkgver}_amd64.AppImage" \
        "$pkgdir/usr/lib/$pkgname/$pkgname.AppImage"

    # Wrapper script
    install -dm755 "$pkgdir/usr/bin"
    cat > "$pkgdir/usr/bin/$pkgname" << 'EOF'
#!/usr/bin/env bash
exec /usr/lib/mo2-linux-helper/mo2-linux-helper.AppImage "$@"
EOF
    chmod +x "$pkgdir/usr/bin/$pkgname"

    # Install helper scripts
    install -dm755 "$pkgdir/usr/lib/$pkgname/scripts"
    install -Dm755 scripts/mo2-setup.sh      "$pkgdir/usr/lib/$pkgname/scripts/mo2-setup.sh"
    install -Dm755 scripts/mo2-nxm.sh        "$pkgdir/usr/lib/$pkgname/scripts/mo2-nxm.sh"
    install -Dm755 scripts/mo2-shortcut.py   "$pkgdir/usr/lib/$pkgname/scripts/mo2-shortcut.py"
    install -Dm755 scripts/mo2-flatpak-setup.sh \
        "$pkgdir/usr/lib/$pkgname/scripts/mo2-flatpak-setup.sh"

    # Symlink scripts to /usr/bin
    ln -s "/usr/lib/$pkgname/scripts/mo2-setup.sh"    "$pkgdir/usr/bin/mo2-setup"
    ln -s "/usr/lib/$pkgname/scripts/mo2-nxm.sh"      "$pkgdir/usr/bin/mo2-nxm"
    ln -s "/usr/lib/$pkgname/scripts/mo2-shortcut.py"  "$pkgdir/usr/bin/mo2-shortcut"

    # Desktop entry
    install -Dm644 /dev/stdin "$pkgdir/usr/share/applications/$pkgname.desktop" << EOF
[Desktop Entry]
Name=MO2 Linux Helper
Comment=Automated Mod Organizer 2 setup for Linux
Exec=mo2-linux-helper
Icon=mo2-linux-helper
Type=Application
Categories=Game;Utility;
Keywords=mods;modding;nexusmods;proton;wine;
EOF

    # License
    install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"

    # Documentation
    install -Dm644 README.md "$pkgdir/usr/share/doc/$pkgname/README.md"
}
