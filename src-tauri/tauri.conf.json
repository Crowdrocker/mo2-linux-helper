{
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devPath": "http://localhost:1420",
    "distDir": "../dist"
  },
  "package": {
    "productName": "MO2 Linux Helper",
    "version": "2.0.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": {
        "all": false,
        "execute": true,
        "sidecar": false,
        "open": true
      },
      "fs": {
        "all": false,
        "readFile": true,
        "writeFile": true,
        "readDir": true,
        "copyFile": true,
        "createDir": true,
        "exists": true,
        "scope": ["$HOME/**", "$APPDATA/**"]
      },
      "path": {
        "all": true
      },
      "http": {
        "all": false,
        "request": true,
        "scope": [
          "https://api.github.com/**",
          "https://github.com/**"
        ]
      },
      "notification": {
        "all": true
      },
      "dialog": {
        "all": false,
        "open": true,
        "save": true
      }
    },
    "bundle": {
      "active": true,
      "targets": ["appimage", "deb"],
      "identifier": "io.github.mo2linuxhelper",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],
      "linux": {
        "deb": {
          "depends": ["wine", "winetricks"]
        },
        "appimage": {
          "bundleMediaFramework": false
        }
      }
    },
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src https://fonts.gstatic.com; img-src 'self' data:"
    },
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/yourusername/mo2-linux-helper/releases/latest/download/latest.json"
      ],
      "dialog": true,
      "pubkey": "YOUR_TAURI_UPDATE_PUBKEY_HERE"
    },
    "windows": [
      {
        "fullscreen": false,
        "resizable": true,
        "title": "MO2 Linux Helper",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": true,
        "transparent": false,
        "center": true
      }
    ]
  }
}
